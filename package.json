{
  "name": "apexcharts-mcp",
  "version": "0.2.0",
  "description": "Model Context Protocol server exposing the ApexCharts ecosystem (charts, gantt, tree, sankey, grid) as tools for AI assistants",
  "type": "module",
  "bin": {
    "apexcharts-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc -b && node scripts/bundle.mjs",
    "dev": "tsc -b --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:versions": "node scripts/check-versions.mjs",
    "verify:skills": "node scripts/verify-skills.mjs",
    "typecheck": "tsc -b",
    "clean": "tsc -b --clean && rm -rf dist",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "apexcharts",
    "apexgantt",
    "apextree",
    "apexsankey",
    "apex-grid",
    "charts",
    "gantt",
    "data-visualization",
    "ai",
    "claude"
  ],
  "author": "ApexCharts",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.20.0",
    "apexcharts-skill": "^1.2.0",
    "apexgantt-skill": "^1.2.0",
    "apexgrid-skill": "^2.0.0",
    "apexsankey-skill": "^1.2.0",
    "apextree-skill": "^1.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
